    owl:inverseOf mk:relates_Entigram_Package_to_Entigram_Agent ;
    rdfs:domain mk:Entigram_Agent ;
    rdfs:range mk:Entigram_Package ;
    rdfs:label "inverse_relates" .

mk:Entigram_Agent rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty mk:relates_Entigram_Agent_to_Entigram_Package ;
        owl:maxCardinality 1
    ] , [
        a owl:Restriction ;
        owl:onProperty mk:relates_Entigram_Agent_to_Entigram_Package ;
        owl:minCardinality 1
    ] .

