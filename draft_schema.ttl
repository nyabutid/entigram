        owl:onProperty mk:relates_Idea_to_Partner_Organization ;
        owl:maxCardinality 1
    ] .

mk:relates_Partner_Organization_to_Idea a owl:ObjectProperty ;
    owl:inverseOf mk:relates_Idea_to_Partner_Organization ;
    rdfs:domain mk:Partner_Organization ;
    rdfs:range mk:Idea ;
    rdfs:label "inverse_relates" .

mk:Partner_Organization rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty mk:relates_Partner_Organization_to_Idea ;
        owl:maxCardinality 1
    ] .

mk:relates_Partner_Organization_to_Supplier a owl:ObjectProperty ;
    rdfs:domain mk:Partner_Organization ;
    rdfs:range mk:Supplier ;
    rdfs:label "relates" .

mk:Partner_Organization rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty mk:relates_Partner_Organization_to_Supplier ;
