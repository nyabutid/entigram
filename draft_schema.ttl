mk:relates_Entigram_Project_to_Entigram_Package a owl:ObjectProperty ;
    rdfs:domain mk:Entigram_Project ;
    rdfs:range mk:Entigram_Package ;
    rdfs:label "relates" .

mk:relates_Entigram_Package_to_Entigram_Project a owl:ObjectProperty ;
    owl:inverseOf mk:relates_Entigram_Project_to_Entigram_Package ;
    rdfs:domain mk:Entigram_Package ;
    rdfs:range mk:Entigram_Project ;
    rdfs:label "inverse_relates" .

mk:Entigram_Package rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty mk:relates_Entigram_Package_to_Entigram_Project ;
        owl:maxCardinality 1
    ] , [
        a owl:Restriction ;
        owl:onProperty mk:relates_Entigram_Package_to_Entigram_Project ;
        owl:minCardinality 1
    ] .

mk:relates_Entigram_Package_to_Entigram_Agent a owl:ObjectProperty ;
    rdfs:domain mk:Entigram_Package ;
