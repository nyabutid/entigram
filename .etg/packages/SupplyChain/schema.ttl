@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix mk: <http://entigram.ai/ontology/custom#> .

mk:Ontology a owl:Ontology ;
    rdfs:label "Entigram Generated Ontology" ;
    mk:generatedAt "2026-05-26T21:12:01.216472" .

mk:Supplier a owl:Class ;
    rdfs:label "Supplier" .

mk:Product a owl:Class ;
    rdfs:label "Product" .

mk:Warehouse a owl:Class ;
    rdfs:label "Warehouse" .

mk:Inventory_Item a owl:Class ;
    rdfs:label "Inventory_Item" .

mk:Supplier_id a owl:DatatypeProperty ;
    rdfs:domain mk:Supplier ;
    rdfs:range xsd:string ;
    rdfs:label "id" .

mk:Supplier_name a owl:DatatypeProperty ;
    rdfs:domain mk:Supplier ;
    rdfs:range xsd:string ;
    rdfs:label "name" .

mk:Supplier_tax_id a owl:DatatypeProperty ;
    rdfs:domain mk:Supplier ;
    rdfs:range xsd:string ;
    rdfs:label "tax_id" .

mk:Supplier_rating a owl:DatatypeProperty ;
    rdfs:domain mk:Supplier ;
    rdfs:range xsd:decimal ;
    rdfs:label "rating" .

mk:Product_id a owl:DatatypeProperty ;
    rdfs:domain mk:Product ;
    rdfs:range xsd:string ;
    rdfs:label "id" .

mk:Product_sku a owl:DatatypeProperty ;
    rdfs:domain mk:Product ;
    rdfs:range xsd:string ;
    rdfs:label "sku" .

mk:Product_name a owl:DatatypeProperty ;
    rdfs:domain mk:Product ;
    rdfs:range xsd:string ;
    rdfs:label "name" .

mk:Product_category a owl:DatatypeProperty ;
    rdfs:domain mk:Product ;
    rdfs:range xsd:string ;
    rdfs:label "category" .

mk:Warehouse_id a owl:DatatypeProperty ;
    rdfs:domain mk:Warehouse ;
    rdfs:range xsd:string ;
    rdfs:label "id" .

mk:Warehouse_location_name a owl:DatatypeProperty ;
    rdfs:domain mk:Warehouse ;
    rdfs:range xsd:string ;
    rdfs:label "location_name" .

mk:Warehouse_capacity a owl:DatatypeProperty ;
    rdfs:domain mk:Warehouse ;
    rdfs:range xsd:integer ;
    rdfs:label "capacity" .

mk:Inventory_Item_id a owl:DatatypeProperty ;
    rdfs:domain mk:Inventory_Item ;
    rdfs:range xsd:string ;
    rdfs:label "id" .

mk:Inventory_Item_quantity a owl:DatatypeProperty ;
    rdfs:domain mk:Inventory_Item ;
    rdfs:range xsd:integer ;
    rdfs:label "quantity" .

mk:Inventory_Item_last_updated a owl:DatatypeProperty ;
    rdfs:domain mk:Inventory_Item ;
    rdfs:range xsd:dateTime ;
    rdfs:label "last_updated" .

mk:relates_Supplier_to_Product a owl:ObjectProperty ;
    rdfs:domain mk:Supplier ;
    rdfs:range mk:Product ;
    rdfs:label "relates" .

mk:relates_Product_to_Supplier a owl:ObjectProperty ;
    owl:inverseOf mk:relates_Supplier_to_Product ;
    rdfs:domain mk:Product ;
    rdfs:range mk:Supplier ;
    rdfs:label "inverse_relates" .

mk:Product rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty mk:relates_Product_to_Supplier ;
        owl:maxCardinality 1
    ] , [
        a owl:Restriction ;
        owl:onProperty mk:relates_Product_to_Supplier ;
        owl:minCardinality 1
    ] .

mk:relates_Warehouse_to_Inventory_Item a owl:ObjectProperty ;
    rdfs:domain mk:Warehouse ;
    rdfs:range mk:Inventory_Item ;
    rdfs:label "relates" .

mk:relates_Inventory_Item_to_Warehouse a owl:ObjectProperty ;
    owl:inverseOf mk:relates_Warehouse_to_Inventory_Item ;
    rdfs:domain mk:Inventory_Item ;
    rdfs:range mk:Warehouse ;
    rdfs:label "inverse_relates" .

mk:Inventory_Item rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty mk:relates_Inventory_Item_to_Warehouse ;
        owl:maxCardinality 1
    ] , [
        a owl:Restriction ;
        owl:onProperty mk:relates_Inventory_Item_to_Warehouse ;
        owl:minCardinality 1
    ] .

mk:relates_Product_to_Inventory_Item a owl:ObjectProperty ;
    rdfs:domain mk:Product ;
    rdfs:range mk:Inventory_Item ;
    rdfs:label "relates" .

mk:relates_Inventory_Item_to_Product a owl:ObjectProperty ;
    owl:inverseOf mk:relates_Product_to_Inventory_Item ;
    rdfs:domain mk:Inventory_Item ;
    rdfs:range mk:Product ;
    rdfs:label "inverse_relates" .

mk:Inventory_Item rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty mk:relates_Inventory_Item_to_Product ;
        owl:maxCardinality 1
    ] , [
        a owl:Restriction ;
        owl:onProperty mk:relates_Inventory_Item_to_Product ;
        owl:minCardinality 1
    ] .
