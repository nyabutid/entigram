        a owl:Restriction ;
        owl:onProperty mk:relates_Package_to_Project ;
        owl:maxCardinality 1
    ] , [
        a owl:Restriction ;
        owl:onProperty mk:relates_Package_to_Project ;
        owl:minCardinality 1
    ] .

